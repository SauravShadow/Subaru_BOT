/**
 * Shadow Garden Command Center — Single-WS Multi-Agent Frontend
 *
 * One persistent WebSocket. All agents share it.
 * Messages are tagged by "agent" field in both directions.
 *
 * Protocol to server:
 *   {type:"message",       agent:"ceo",      text:"..."}
 *   {type:"model",         model:"claude"}
 *   {type:"clear",         agent:"ceo"}
 *   {type:"force_complete",task_id:5}
 *   {type:"reset_task",    task_id:5}
 *   {type:"cancel_worker", agent:"reinhard"}
 *
 * Protocol from server:
 *   {type:"init",          agents:{...}, work_queue:[...]}
 *   {type:"thinking",      agent:"..."}
 *   {type:"assistant",     agent:"...", message:{content:[...]}}
 *   {type:"tool_call",     agent:"...", tool:"bash", label:"...", path:"..."}
 *   {type:"done",          agent:"..."}
 *   {type:"worker_done",   agent:"...", task_id:5, summary:"..."}
 *   {type:"delegation",    item:{...}}
 *   {type:"queue_update",  work_queue:[...]}
 *   {type:"cleared",       agent:"..."}
 *   {type:"failover",      agent:"...", message:"..."}
 *   {type:"error",         agent:"...", message:"..."}
 *   {type:"email_sent",    subject:"...", ok:true}
 */

"use strict";

// ── State ─────────────────────────────────────────────────────────────────────

const S = {
  ws:            null,
  agents:        {},          // id → {name,title,color,avatar,description}
  agentOrder:    [],          // ordered list of agent ids
  activeAgent:   "ceo",      // which agent's chat is visible
  backend:       "claude",   // tracked from server; not user-controlled
  chatLogs:      {},          // agent_id → [{role,content,ts}]
  statuses:      {},          // agent_id → "ready"|"thinking"|"working"|"error"
  unread:        {},          // agent_id → count since last viewed
  workQueue:     [],
  thinkingEl:    null,        // DOM element for the spinning indicator
  voiceRecording: false,
  mediaRecorder: null,
  reconnTimer:   null,
};

// Worker IDs for distinguishing background/foreground
const CEO_ID = "ceo";
const WORKER_IDS = new Set(["backend","frontend","qa","devops"]);

