function getAnimeAvatar(agentId) {
  const svg = ANIME_AVATARS[agentId];
  if (!svg) return null;
  return svg;
}

// ── Utilities ─────────────────────────────────────────────────────────────────

const esc = s => String(s ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
const escHtml = esc;

function fmtTime(iso) {
  if (!iso) return "";
  const d = new Date(iso);
  return d.toLocaleTimeString([], {hour:"2-digit",minute:"2-digit"});
}

function fmtRelativeTime(iso) {
  if (!iso) return "";
  const diff = Date.now() - new Date(iso).getTime();
  if (diff < 60000)  return "just now";
  if (diff < 3600000) return `${Math.floor(diff/60000)}m ago`;
  return `${Math.floor(diff/3600000)}h ago`;
}

/** Render markdown-ish text — bold, inline code, code blocks */
function renderMarkdown(text) {
  text = esc(text);
  // Code blocks
  text = text.replace(/```[\w]*\n([\s\S]*?)```/g,
    (_,c) => `<pre style="background:rgba(0,0,0,.4);border:1px solid var(--border);border-radius:6px;padding:10px 12px;overflow-x:auto;font-size:11.5px;margin:6px 0;font-family:'JetBrains Mono',monospace;line-height:1.45;">${c}</pre>`);
  // Inline code
  text = text.replace(/`([^`]+)`/g,
    (_,c) => `<code style="background:rgba(0,0,0,.4);border:1px solid var(--border);border-radius:3px;padding:1px 5px;font-family:'JetBrains Mono',monospace;font-size:12px;">${c}</code>`);
  // Bold
  text = text.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
  // H3
  text = text.replace(/^### (.+)$/gm, '<div style="font-size:14px;font-weight:700;color:var(--text);margin:10px 0 4px;">$1</div>');
  // H2
  text = text.replace(/^## (.+)$/gm,  '<div style="font-size:16px;font-weight:700;color:var(--ceo);margin:12px 0 6px;">$1</div>');
  // Bullet
  text = text.replace(/^[•\-\*] (.+)$/gm, '<div style="padding-left:14px;margin:2px 0;">• $1</div>');
  // Line breaks
  text = text.replace(/\n/g, "<br>");
  return text;
}

function $id(id) { return document.getElementById(id); }
function agentColor(id) { return S.agents[id]?.color || "#94a3b8"; }
function agentName(id)  { return S.agents[id]?.name  || id; }
function agentAvatar(id){ return S.agents[id]?.avatar || id.slice(0,2).toUpperCase(); }

function updateBackendPill(backendObj) {
  S.backend = backendObj.backend || "claude";
  const isClaude = S.backend === "claude";
  const pill  = $id("backend-pill");
  const icon  = $id("backend-icon");
  const val   = $id("backend-val");
  if (!pill) return;

  if (isClaude) {
    pill.style.color = "var(--ok)";
    icon.textContent  = "⚡";
    val.textContent   = "Claude CLI";
    pill.title        = "Using Claude CLI (Pro)";
  } else {
    const retryAt = backendObj.retry_at ? ` — retry at ${backendObj.retry_at}` : "";
    pill.style.color = "var(--warn)";
    icon.textContent  = "⚡";
    val.textContent   = "ChatGPT (fallback)";
    pill.title        = `Claude quota hit${retryAt}`;
  }
}

// ── Toast ─────────────────────────────────────────────────────────────────────

function toast(msg, type = "info") {
  const box = $id("toast-box");
  const t = document.createElement("div");
  t.className = `toast ${type}`;
  const icon = {info:"ℹ️", success:"✅", warn:"⚠️", error:"❌"}[type] || "ℹ️";
  t.innerHTML = `<span>${icon}</span><span style="flex:1">${esc(msg)}</span>`;
  box.appendChild(t);
  setTimeout(() => { t.classList.add("fade-out"); setTimeout(()=>t.remove(), 300); }, 5000);
}

// ── WebSocket ─────────────────────────────────────────────────────────────────

function boot() {
  if (S.reconnTimer) { clearTimeout(S.reconnTimer); S.reconnTimer = null; }
  if (S.ws && S.ws.readyState < 2) S.ws.close();

  const proto = location.protocol === "https:" ? "wss:" : "ws:";
  const url = `${proto}//${location.host}/ws`;
  S.ws = new WebSocket(url);

  S.ws.addEventListener("open", () => {
    $id("ws-status").textContent = "Connected";
    $id("ws-pill").style.color = "var(--ok)";
    $id("reconnect-banner").classList.remove("visible");
  });

  S.ws.addEventListener("close", () => {
    $id("ws-status").textContent = "Disconnected";
    $id("ws-pill").style.color = "var(--err)";
    $id("reconnect-banner").classList.add("visible");
    S.reconnTimer = setTimeout(boot, 4000);
  });

  S.ws.addEventListener("error", () => {
    $id("ws-status").textContent = "Error";
  });

  S.ws.addEventListener("message", e => {
    let obj;
    try { obj = JSON.parse(e.data); } catch { return; }
    dispatch(obj);
  });
}

function wsSend(obj) {
  if (S.ws && S.ws.readyState === 1) {
    S.ws.send(JSON.stringify(obj));
  }
}

// ── Event dispatcher ──────────────────────────────────────────────────────────

function dispatch(obj) {
  const agent = obj.agent || "ceo";

  switch (obj.type) {

    case "init":
      S.agents    = obj.agents || {};
      S.agentOrder= Object.keys(S.agents);
      S.workQueue = obj.work_queue || [];
      // Initialise per-agent state
      S.agentOrder.forEach(id => {
        if (!S.chatLogs[id])  S.chatLogs[id]  = [];
        if (!S.unread[id])    S.unread[id]    = 0;
        // On reconnect: no task is running server-side, so clear any stale thinking state
        const runningTask = (S.workQueue).find(t => t.agent === id && t.status === 'running');
        S.statuses[id] = runningTask ? "working" : "ready";
      });
      clearThinking();
      renderSidebar();
      renderChatHeader();
      updateQueuePill();
      refreshDashboard();
      loadStorageStats();
      loadCapabilities();
      if (obj.backend) updateBackendPill(obj.backend);
      if (obj.changelog) renderChangelog(obj.changelog);
      if (obj.task_history) renderTaskHistory(obj.task_history);
      const sb = document.getElementById('sys-backend');
      if (sb && obj.backend) sb.textContent = obj.backend.backend === 'claude' ? 'Claude CLI' : 'tgpt (fallback)';
      break;

    case "task_history_update":
      renderTaskHistory(obj.task_history || []);
      break;

    case "thinking":
      setStatus(agent, "thinking");
      if (window._canvasSetActivity) window._canvasSetActivity(1);
      if (agent === S.activeAgent) showThinking(agent);
      else pushWorkerEvent(agent, "thinking", `${agentName(agent)} is thinking…`);
      break;

    case "assistant": {
      clearThinking();
      const content = obj.message?.content || [];
      let text = content.map(b => b.type === "text" ? b.text : "").join("");
      if (!text.trim()) break;

      if (agent === S.activeAgent) {
        // Stream in character by character
        const msgs = $id("messages");
        if (msgs) {
          const color = agentColor(agent);
          const animeSvg = getAnimeAvatar(agent);
          const row = document.createElement("div");
          row.className = "msg-row assistant";
          row.innerHTML = `<div class="msg-av" style="background:${color}15;border-color:${color}44;">${animeSvg || `<span style="color:${color};font-size:10px;font-weight:700;">${agentAvatar(agent)}</span>`}</div><div class="msg-bubble"></div>`;
          msgs.appendChild(row);
          msgs.scrollTop = msgs.scrollHeight;
          const bubble = row.querySelector(".msg-bubble");
          startStreaming(agent, bubble);
          feedStream(agent, text);
        }
        if (!S.chatLogs[agent]) S.chatLogs[agent] = [];
        S.chatLogs[agent].push({ role: "assistant", content: text, ts: new Date().toISOString(), type: "text" });
      } else {
        pushMsg(agent, "assistant", text);
        bumpUnread(agent);
      }
      break;
    }

    case "tool_call": {
      const card = buildToolCard(obj.tool, obj.label, obj.path || obj.cmd || "");
      pushRawHtml(agent, card);
      if (agent !== S.activeAgent) bumpUnread(agent);
      break;
    }

    case "done":
      setStatus(agent, "ready");
      endStream(agent);
      clearThinking();
      enableInput();
      {
        const anyActive = Object.values(S.statuses).some(s => s === "thinking" || s === "working");
        if (window._canvasSetActivity) window._canvasSetActivity(anyActive ? 1 : 0);
      }
      break;

    case "worker_done": {
      setStatus(agent, "ready");
      const summaryHtml = `
        <div class="worker-event done">
          <div class="worker-event-header">
            <span class="worker-event-badge" style="color:${agentColor(agent)}">${agentAvatar(agent)} ${agentName(agent)}</span>
            <span style="color:var(--ok)">✓ Task #${obj.task_id} Complete</span>
          </div>
          <div style="font-size:11px;color:var(--text-dim);margin-top:4px;">${esc(obj.summary || "Done.")}</div>
        </div>`;
      // Always show completion in CEO's chat AND in the worker's chat
      pushRawHtml(CEO_ID, summaryHtml);
      pushRawHtml(agent, summaryHtml);
      if (S.activeAgent !== CEO_ID) bumpUnread(CEO_ID);
      if (S.activeAgent !== agent)  bumpUnread(agent);
      fetch('/api/changelog').then(r => r.json()).then(renderChangelog).catch(() => {});
      break;
    }

    case "delegation": {
      const item = obj.item;
      S.workQueue.push(item);
      updateQueuePill();
      renderTaskRegistry();
      spawnDelegationPulse(item.agent);
      const deleg = `
        <div class="worker-event thinking">
          <div class="worker-event-header">
            <span class="worker-event-badge" style="color:var(--warn)">📋 Delegated</span>
            <span style="color:var(--text-dim)">→ ${agentName(item.agent)}</span>
          </div>
          <div style="font-size:11px;color:var(--text-dim);margin-top:4px;">${esc((item.task||"").slice(0,120))}</div>
        </div>`;
      pushRawHtml(CEO_ID, deleg);
      break;
    }

    case "queue_update":
      S.workQueue = obj.work_queue || [];
      updateQueuePill();
      renderTaskRegistry();
      break;

    case "cleared":
      S.chatLogs[agent] = [];
      if (agent === S.activeAgent) renderMessages();
      toast(`Chat cleared for ${agentName(agent)}`, "info");
      break;

    case "failover":
      toast(obj.message || "Provider failover", "warn");
      break;

    case "error": {
      clearThinking();
      setStatus(agent, "error");
      enableInput();
      const errHtml = `<div style="color:var(--err);font-size:12px;padding:4px 0;">⚠ ${esc(obj.message)}</div>`;
      pushRawHtml(agent, errHtml);
      toast(obj.message, "error");
      break;
    }

    case "email_sent":
      toast(obj.ok ? `✉ Email sent: ${obj.subject}` : `Email failed: ${obj.error}`,
            obj.ok ? "success" : "error");
      break;

    case "pong": break;

    case "backend_status":
      updateBackendPill(obj);
      { const sb = $id("sys-backend");
        if (sb) sb.textContent = obj.backend === "claude" ? "Claude CLI" : "tgpt (fallback)"; }
      if (!obj.quota_ok) {
        toast(`Claude quota hit — switched to tgpt fallback`, "warn");
      } else if (obj.backend === "claude") {
        toast("Claude CLI recovered ✓", "success");
      }
      break;

    default:
      // Legacy raw JSON from Claude CLI passthrough
      if (obj._raw_json) return;
      console.log("[unknown event]", obj);
  }
}

// ── Chat log management ───────────────────────────────────────────────────────

function pushMsg(agentId, role, text) {
  S.chatLogs[agentId] = S.chatLogs[agentId] || [];
  const entry = { role, content: text, ts: new Date().toISOString(), type: "text" };
  S.chatLogs[agentId].push(entry);
  if (agentId === S.activeAgent) appendMsgEl(agentId, entry);
}

function pushRawHtml(agentId, html) {
  S.chatLogs[agentId] = S.chatLogs[agentId] || [];
  const entry = { role: "system", content: html, ts: new Date().toISOString(), type: "html" };
  S.chatLogs[agentId].push(entry);
  if (agentId === S.activeAgent) appendMsgEl(agentId, entry);
}

function pushWorkerEvent(agentId, evtType, text) {
  const cls  = { thinking:"thinking", done:"done", error:"error" }[evtType] || "";
  const html = `
    <div class="worker-event ${cls}">
      <div class="worker-event-header">
        <span class="worker-event-badge" style="color:${agentColor(agentId)}">${agentAvatar(agentId)} ${agentName(agentId)}</span>
        <span style="color:var(--text-dim);font-size:10px;">${esc(text)}</span>
      </div>
    </div>`;
  // Show in CEO's feed
  pushRawHtml(CEO_ID, html);
  if (S.activeAgent !== CEO_ID) bumpUnread(CEO_ID);
}

// ── DOM rendering ─────────────────────────────────────────────────────────────

function appendMsgEl(agentId, entry) {
  const container = $id("messages");
  const el = buildMsgEl(agentId, entry);
  container.appendChild(el);
  container.scrollTop = container.scrollHeight;
  return el;
}

function buildMsgEl(agentId, entry) {
  const { role, content, type } = entry;

  if (type === "html") {
    const wrapper = document.createElement("div");
    wrapper.innerHTML = content;
    return wrapper;
  }

  if (role === "user") {
    const div = document.createElement("div");
    div.className = "msg-row user";
    div.innerHTML = `
      <div class="msg-av" style="background:rgba(0,212,255,.12);border-color:rgba(0,212,255,.3);color:var(--ceo);font-family:var(--font-display);font-weight:700;font-size:10px;">YOU</div>
      <div class="msg-bubble">${renderMarkdown(content)}</div>`;
    return div;
  }

  // assistant (history replay — no streaming)
  const color  = agentColor(agentId);
  const avatar = agentAvatar(agentId);
  const animeSvg = getAnimeAvatar(agentId);
  const div = document.createElement("div");
  div.className = "msg-row assistant";
  div.innerHTML = `
    <div class="msg-av" style="background:${color}15;border-color:${color}44;">
      ${animeSvg || `<span style="color:${color};font-size:10px;font-weight:700;">${avatar}</span>`}
    </div>
    <div class="msg-bubble">${renderMarkdown(content)}</div>`;
  return div;
}

function buildToolCard(tool, label, path) {
  const icons = { bash:"⚙", read:"📖", write:"✍", edit:"✏", read_inbox:"📬" };
  const icon = icons[tool] || "🔧";
  return `<div class="tool-card">
    <span class="tool-icon">${icon}</span>
    <span class="tool-label">${esc(label || tool)}</span>
    ${path ? `<span class="tool-path" title="${esc(path)}">${esc(path)}</span>` : ""}
  </div>`;
}

function renderMessages() {
  const el = $id("messages");
  el.innerHTML = "";
  const logs = S.chatLogs[S.activeAgent] || [];
  logs.forEach(entry => appendMsgEl(S.activeAgent, entry));
  el.scrollTop = el.scrollHeight;
}

// ── Thinking indicator (EKG) ──────────────────────────────────────────────────

function showThinking(agentId) {
  clearThinking();
  const msgs = $id("messages");
  if (!msgs) return;
  const animeSvg = getAnimeAvatar(agentId);
  const color = agentColor(agentId);
  const el = document.createElement("div");
  el.className = "msg-row assistant";
  el.id = "thinking-indicator";
  el.innerHTML = `
    <div class="msg-av" style="background:${color}15;border-color:${color}44;">
      ${animeSvg || `<span style="color:${color};font-size:11px;font-weight:700;">${agentAvatar(agentId)}</span>`}
    </div>
    <div class="msg-thinking">
      <span class="msg-thinking-label">Thinking</span>
      <svg class="msg-thinking-ekg" viewBox="0 0 80 14">
        <path d="M0,7 L18,7 L24,2 L30,12 L36,7 L50,7 L55,3 L61,11 L67,7 L80,7"/>
      </svg>
    </div>`;
  msgs.appendChild(el);
  msgs.scrollTop = msgs.scrollHeight;
  S.thinkingEl = el;
  disableInput();
}

// ── Streaming typewriter ───────────────────────────────────────────────────────

const _streams = {};

function startStreaming(agentId, bubbleEl) {
  if (_streams[agentId]) {
    const old = _streams[agentId];
    if (old.cursor && old.cursor.parentNode) old.cursor.remove();
  }
  const cursor = document.createElement("span");
  cursor.className = "stream-cursor";
  bubbleEl.appendChild(cursor);
  _streams[agentId] = { el: bubbleEl, cursor, queue: [], running: false };
}

function feedStream(agentId, text) {
  const s = _streams[agentId];
  if (!s) return;
  for (const ch of text) s.queue.push(ch);
  if (!s.running) _drainStream(agentId);
}

function _drainStream(agentId) {
  const s = _streams[agentId];
  if (!s || !s.queue.length) { if (s) s.running = false; return; }
  s.running = true;
  const ch = s.queue.shift();
  s.el.insertBefore(document.createTextNode(ch), s.cursor);
  const msgs = $id("messages");
  if (msgs) msgs.scrollTop = msgs.scrollHeight;
  setTimeout(() => _drainStream(agentId), 14);
}

function endStream(agentId) {
  const s = _streams[agentId];
  if (!s) return;
  const waitAndRemove = () => {
    if (s.queue.length > 0) { setTimeout(waitAndRemove, 20); return; }
    if (s.cursor && s.cursor.parentNode) s.cursor.remove();
    delete _streams[agentId];
  };
  setTimeout(waitAndRemove, 50);
}

// ── Particle canvas background ────────────────────────────────────────────────

(function initParticleCanvas() {
  const canvas = document.getElementById("bg-canvas");
  if (!canvas) return;
  const ctx = canvas.getContext("2d");
  let W, H, particles, activityLevel = 0;

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  function makeParticle() {
    return {
      x:  Math.random() * (W || 800),
      y:  Math.random() * (H || 600),
      vx: (Math.random() - .5) * .22,
      vy: (Math.random() - .5) * .22,
      r:  Math.random() * 1.1 + .4,
      a:  Math.random() * .35 + .08,
    };
  }
  window._canvasSetActivity = v => { activityLevel = v; };
  let _actSmooth = 0;
  function tick() {
    _actSmooth += (activityLevel - _actSmooth) * .03;
    const sp = 1 + _actSmooth * 2.2;
    ctx.clearRect(0, 0, W, H);
    particles.forEach(p => {
      p.x += p.vx * sp; p.y += p.vy * sp;
      if (p.x < -2) p.x = W + 2; if (p.x > W + 2) p.x = -2;
      if (p.y < -2) p.y = H + 2; if (p.y > H + 2) p.y = -2;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(0,212,255,${p.a + _actSmooth * .14})`;
      ctx.fill();
    });
    requestAnimationFrame(tick);
  }
  window.addEventListener("resize", () => {
    resize();
    particles.forEach(p => { p.x = Math.min(p.x, W); p.y = Math.min(p.y, H); });
  });
  resize();
  particles = Array.from({ length: 28 }, makeParticle);
  tick();
})();

// ── Delegation pulse ──────────────────────────────────────────────────────────

function spawnDelegationPulse(toAgentId) {
  const ceoEl = document.querySelector("[data-agent-id='ceo']");
  const toEl  = document.querySelector(`[data-agent-id='${toAgentId}']`);
  if (!ceoEl || !toEl) return;
  const r1 = ceoEl.getBoundingClientRect();
  const r2 = toEl.getBoundingClientRect();
  const x1 = r1.left + r1.width / 2, y1 = r1.top  + r1.height / 2;
  const x2 = r2.left + r2.width / 2, y2 = r2.top  + r2.height / 2;
  const dot = document.createElement("div");
  dot.className = "delegation-pulse";
  const agColors = { backend:"#ff8c42", frontend:"#f472b6", qa:"#a78bfa", devops:"#34d399" };
  const col = agColors[toAgentId] || (S.agents[toAgentId] && S.agents[toAgentId].color) || "#00d4ff";
  dot.style.cssText = `left:${x1}px;top:${y1}px;background:${col};box-shadow:0 0 12px ${col},0 0 4px white`;
  document.body.appendChild(dot);
  const dur = 600, t0 = performance.now();
  function step(now) {
    const t = Math.min((now - t0) / dur, 1);
    const e = t < .5 ? 2*t*t : -1+(4-2*t)*t;
    dot.style.left    = (x1 + (x2-x1)*e) + "px";
    dot.style.top     = (y1 + (y2-y1)*e) + "px";
    dot.style.opacity = t < .9 ? 1 : (1-t)*10;
    t < 1 ? requestAnimationFrame(step) : dot.remove();
  }
  requestAnimationFrame(step);
}

function clearThinking() {
  if (S.thinkingEl) { S.thinkingEl.remove(); S.thinkingEl = null; }
}

// ── Agent switching ───────────────────────────────────────────────────────────

function switchAgent(id) {
  if (!S.agents[id]) return;
  S.activeAgent = id;
  S.unread[id]  = 0;
  renderSidebar();
  renderChatHeader();
  renderMessages();
  updateInputPlaceholder();
  const cancelBtn = $id("btn-cancel-worker");
  if (cancelBtn) {
    cancelBtn.style.display = (S.statuses[id] === "thinking" || S.statuses[id] === "working") ? "flex" : "none";
  }
}

function cycleAgent() {
  const ids  = S.agentOrder;
  const idx  = ids.indexOf(S.activeAgent);
  const next = ids[(idx + 1) % ids.length];
  switchAgent(next);
}

function updateInputPlaceholder() {
  const inp = $id("message-input");
  if (!inp) return;
  const name = agentName(S.activeAgent);
  inp.placeholder = `Message ${name}…`;
}

// ── Agent Hierarchy Panel ─────────────────────────────────────────────────────

function renderSidebar() { renderAgentPanel(); }  // backward compat alias
function renderAgentTabs() { renderAgentPanel(); } // backward compat alias

// Task timers: agent_id → {task_text, started_iso}
const _activeTimers = {};
let _timerInterval = null;

function _startTimers() {
  if (_timerInterval) return;
  _timerInterval = setInterval(() => {
    document.querySelectorAll('.hier-timer[data-start]').forEach(el => {
      const diff = Date.now() - parseInt(el.dataset.start);
      const s = Math.floor(diff / 1000);
      const m = Math.floor(s / 60);
      el.textContent = m > 0 ? `${m}m ${s % 60}s` : `${s}s`;
    });
  }, 1000);
}

function getActiveTask(agentId) {
  return S.workQueue.find(t => t.agent === agentId && t.status === 'running') || null;
}

function renderAgentPanel() {
  const inner = $id("agent-panel-inner");
  if (!inner) return;
  inner.innerHTML = "";

  const ceo = S.agents[CEO_ID];
  if (ceo) {
    const status    = S.statuses[CEO_ID] || "ready";
    const isActive  = S.activeAgent === CEO_ID;
    const animeSvg  = getAnimeAvatar(CEO_ID);
    const isWorking = status === "thinking" || status === "working";

    const ceoCard = document.createElement("div");
    ceoCard.className = `hier-ceo-card${isActive ? " active" : ""}${isWorking ? " thinking" : ""}`;
    ceoCard.dataset.agentId = CEO_ID;
    ceoCard.onclick = () => switchAgent(CEO_ID);
    ceoCard.innerHTML = `
      <div class="hier-ceo-top">
        <div class="hier-ceo-av${isWorking ? " scanning" : ""}">
          ${animeSvg || `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;color:${ceo.color};">${ceo.avatar}</div>`}
        </div>
        <div class="hier-ceo-info">
          <div class="hier-ceo-name">${esc(ceo.name)}</div>
          <div class="hier-ceo-title">${esc(ceo.title)}</div>
        </div>
      </div>
      <div class="hier-ceo-status">
        <div class="status-dot${isWorking ? " thinking" : ""}"></div>
        <span>${isWorking ? "Thinking…" : "Ready"}</span>
      </div>
      <div class="ekg-container${isWorking ? " visible" : ""}">
        <svg class="ekg-line" viewBox="0 0 100 16">
          <path class="ekg-path" d="M0,8 L20,8 L28,2 L34,14 L40,8 L55,8 L60,4 L66,12 L72,8 L100,8"/>
        </svg>
      </div>`;
    inner.appendChild(ceoCard);
  }

  // Workers section
  const workers = S.agentOrder.filter(id => id !== CEO_ID);
  if (workers.length) {
    const label = document.createElement("div");
    label.className = "hier-team-label";
    label.textContent = "Team";
    inner.appendChild(label);

    workers.forEach(id => {
      const agent     = S.agents[id];
      if (!agent) return;
      const status    = S.statuses[id] || "ready";
      const isActive  = S.activeAgent === id;
      const animeSvg  = getAnimeAvatar(id);
      const activeTask = getActiveTask(id);
      const isWorking = status === "thinking" || status === "working";
      const isCustom  = !["backend","frontend","qa","devops"].includes(id);
      const unread    = S.unread[id] || 0;
      const roleClass = isCustom ? "custom" : id;
      const startMs   = activeTask ? new Date(activeTask.created).getTime() : Date.now();
      const taskPreview = activeTask ? (activeTask.summary || activeTask.task || "").slice(0, 55) : "";

      const card = document.createElement("div");
      card.className = `hier-worker-card${isActive ? " active" : ""}${isWorking ? " working " + roleClass : ""}`;
      card.dataset.agentId = id;
      card.onclick = () => switchAgent(id);
      card.innerHTML = `
        <div class="hier-worker-top">
          <div class="hier-worker-av${isWorking ? " scanning" : ""}" style="${isWorking ? "border-color:" + agent.color : ""}">
            ${animeSvg || `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:10px;color:${agent.color};background:${agent.color}18;">${agent.avatar}</div>`}
          </div>
          <div class="hier-worker-info">
            <div class="hier-worker-name" style="color:${agent.color}">
              ${esc(agent.name.split(" ")[0])}
              ${unread > 0 ? `<span style="background:${agent.color};color:#000;font-size:8px;padding:1px 4px;border-radius:99px;margin-left:3px;">${unread}</span>` : ""}
            </div>
            <div class="hier-worker-subtitle">${esc(agent.title)}</div>
          </div>
        </div>
        <div class="hier-status-row">
          <div class="hier-dot${isWorking ? " working" : ""}" style="${isWorking ? "background:" + agent.color : ""}"></div>
          ${taskPreview
            ? `<span class="hier-task-preview">${esc(taskPreview)}</span><span class="hier-timer" data-start="${startMs}"></span>`
            : `<span class="hier-task-preview" style="color:var(--text-mute)">${isWorking ? "Working…" : "Ready"}</span>`
          }
        </div>
        ${isCustom ? `<button class="hier-delete" onclick="fireAgent(event,'${id}')" title="Remove">✕</button>` : ""}`;
      inner.appendChild(card);
    });
  }

  _startTimers();

  // Update input bar badge
  const activeAgent = S.agents[S.activeAgent];
  const badge = $id("badge-av");
  const badgeName = $id("badge-name");
  if (badge && activeAgent) {
    const svg = getAnimeAvatar(S.activeAgent);
    if (svg) {
      badge.innerHTML = svg;
      badge.style.color = activeAgent.color;
    } else {
      badge.textContent = activeAgent.avatar;
      badge.style.color = activeAgent.color;
    }
    if (badgeName) {
      badgeName.textContent = activeAgent.name.split(" ")[0];
      badgeName.style.color = activeAgent.color;
    }
  }

  updateSysTeamDots();
}

async function fireAgent(e, agentId) {
  e.stopPropagation();
  if (!confirm(`Remove ${S.agents[agentId]?.name || agentId} from the team?`)) return;
  const res = await fetch(`/api/hire/${agentId}`, { method: "DELETE" });
  const d   = await res.json();
  if (d.ok) {
    delete S.agents[agentId];
    S.agentOrder = S.agentOrder.filter(id => id !== agentId);
    if (S.activeAgent === agentId) switchAgent(CEO_ID);
    else renderAgentPanel();
    toast(`${agentId} removed.`, "info");
  } else {
    toast(d.error || "Could not remove agent.", "error");
  }
}

// renderAgentTabs_old removed — renderAgentPanel handles everything

function updateSysTeamDots() {
  const el = $id("sys-team-dots");
  if (!el) return;
  el.innerHTML = S.agentOrder.map(id => {
    const a = S.agents[id];
    if (!a) return "";
    const st = S.statuses[id] || "ready";
    const dotColor = st === "ready" ? "var(--ok)" : st === "error" ? "var(--err)" : "var(--warn)";
    return `<div class="team-dot" style="background:${dotColor};box-shadow:0 0 4px ${dotColor}40;" title="${esc(a.name)}: ${st}"></div>`;
  }).join("");
}

function setStatus(id, status) {
  S.statuses[id] = status;
  renderSidebar();
  if (id === S.activeAgent) renderChatHeader();
  const cancelBtn = $id("btn-cancel-worker");
  if (cancelBtn && id === S.activeAgent) {
    cancelBtn.style.display = (status === "thinking" || status === "working") ? "flex" : "none";
  }
}

function bumpUnread(id) {
  if (id === S.activeAgent) return;
  S.unread[id] = (S.unread[id] || 0) + 1;
  renderSidebar();
}

// ── Chat header ───────────────────────────────────────────────────────────────

function renderChatHeader() {
  const agent  = S.agents[S.activeAgent];
  if (!agent) return;
  const status = S.statuses[S.activeAgent] || "ready";
  const av     = $id("chat-av");
  const nm     = $id("chat-name");
  const st     = $id("chat-status");
  if (!av || !nm || !st) return;

  const animeSvg = getAnimeAvatar(S.activeAgent);
  av.style.background = `${agent.color}15`;
  av.style.border     = `1.5px solid ${agent.color}44`;
  if (animeSvg) {
    av.innerHTML = animeSvg;
    av.style.color = "";
  } else {
    av.innerHTML = `<span style="font-weight:700;font-size:11px;color:${agent.color}">${agent.avatar}</span>`;
  }
  nm.textContent = agent.name;
  nm.style.color = agent.color;

  const statusLabels = { ready:"● Ready", thinking:"● Thinking…", working:"⚙ Working…", error:"⚠ Error" };
  st.textContent = statusLabels[status] || status;
  st.style.color = status === "ready" ? "var(--ok)" : status === "error" ? "var(--err)" : "var(--warn)";
}

// ── Send message ──────────────────────────────────────────────────────────────

function sendMessage() {
  const inp   = $id("message-input");
  const text  = inp.value.trim();
  if (!text) return;

  // Optimistic render
  pushMsg(S.activeAgent, "user", text);

  // Send to server
  wsSend({ type: "message", agent: S.activeAgent, text });

  inp.value = "";
  inp.style.height = "";
  setStatus(S.activeAgent, "thinking");
  if (S.activeAgent === CEO_ID) showThinking(S.activeAgent);
  disableInput();
}

function disableInput() {
  const inp  = $id("message-input");
  const btn  = $id("btn-send");
  if (inp) inp.disabled = S.activeAgent === CEO_ID;  // Only block if talking to CEO
  if (btn) btn.disabled = S.activeAgent === CEO_ID;
}

function enableInput() {
  const inp = $id("message-input");
  const btn = $id("btn-send");
  if (inp) inp.disabled = false;
  if (btn) btn.disabled = false;
}

function clearChat() {
  wsSend({ type: "clear", agent: S.activeAgent });
}

function cancelWorker() {
  wsSend({ type: "cancel_worker", agent: S.activeAgent });
  toast(`Cancelling ${agentName(S.activeAgent)}…`, "warn");
}

// ── Input events ──────────────────────────────────────────────────────────────

function initInputEvents() {
  const inp = $id("message-input");
  const btn = $id("btn-send");

  inp.addEventListener("input", () => {
    inp.style.height = "auto";
    inp.style.height = Math.min(inp.scrollHeight, 140) + "px";
  });

  inp.addEventListener("keydown", e => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  btn.addEventListener("click", sendMessage);
}

// ── Voice input ───────────────────────────────────────────────────────────────

function initVoice() {
  const btn = $id("btn-voice");
  if (!btn) return;

  if (!("webkitSpeechRecognition" in window) && !("SpeechRecognition" in window)) {
    btn.title = "Speech recognition not supported in this browser";
    btn.style.opacity = ".4";
    return;
  }

  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  const recog = new SpeechRecognition();
  recog.continuous = false;
  recog.lang       = "en-US";

  recog.onresult = e => {
    const text = e.results[0][0].transcript;
    $id("message-input").value = text;
  };
  recog.onend = () => {
    btn.classList.remove("recording");
    S.voiceRecording = false;
  };

  btn.addEventListener("click", () => {
    if (S.voiceRecording) { recog.stop(); return; }
    S.voiceRecording = true;
    btn.classList.add("recording");
    recog.start();
  });
}

// ── Tabs ──────────────────────────────────────────────────────────────────────

function switchTab(name) {
  const chatView  = $id("chat-view");
  const dashView  = $id("dashboard-view");
  const tabChat   = $id("tab-chat");
  const tabDash   = $id("tab-dash");

  if (name === "chat") {
    chatView.style.display = "flex";
    dashView.classList.remove("visible");
    tabChat.classList.add("active");
    tabDash.classList.remove("active");
    // noop
  } else {
    chatView.style.display = "none";
    dashView.classList.add("visible");
    tabChat.classList.remove("active");
    tabDash.classList.add("active");
    refreshDashboard();
  }
}

// ── Dashboard ─────────────────────────────────────────────────────────────────

function refreshDashboard() {
  renderTaskRegistry();
  loadEmailTasks();
  loadCapabilities();
  loadStorageStats();
}

function renderOrgChart() {
  const el = $id("org-chart");
  if (!el || !S.agents[CEO_ID]) return;

  const ceo    = S.agents[CEO_ID];
  const status = S.statuses[CEO_ID] || "ready";

  el.innerHTML = `
    <div class="org-ceo" onclick="switchAgent('${CEO_ID}');switchTab('chat');" style="cursor:pointer;">
      <div class="agent-avatar" style="background:${ceo.color}22;border:2px solid ${ceo.color}44;color:${ceo.color};width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;font-family:'Rajdhani',sans-serif;flex-shrink:0;">${ceo.avatar}</div>
      <div style="flex:1;">
        <div style="font-size:14px;font-weight:700;color:${ceo.color};">${esc(ceo.name)}</div>
        <div style="font-size:11px;color:var(--text-dim);">${esc(ceo.title)}</div>
      </div>
      <div class="agent-status ${status}"></div>
    </div>
    <div class="org-workers">
      ${S.agentOrder.filter(id=>id!==CEO_ID).map(id => {
        const a = S.agents[id];
        if (!a) return "";
        const st = S.statuses[id] || "ready";
        return `<div class="org-worker" onclick="switchAgent('${id}');switchTab('chat');" title="${esc(a.description)}">
          <div style="width:28px;height:28px;border-radius:50%;background:${a.color}22;border:1px solid ${a.color}44;color:${a.color};display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;font-family:'Rajdhani',sans-serif;flex-shrink:0;">${a.avatar}</div>
          <div style="flex:1;min-width:0;">
            <div style="font-size:12px;font-weight:600;color:${a.color};white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(a.name)}</div>
            <div style="font-size:10px;color:var(--text-mute);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(a.title)}</div>
          </div>
          <div class="agent-status ${st}"></div>
        </div>`;
      }).join("")}
    </div>`;
}

function renderTaskRegistry() {
  const el = $id("task-registry");
  if (!el) return;

  const queue   = S.workQueue;
  const counts  = $id("task-counts");
  const pending  = queue.filter(t=>t.status==="pending").length;
  const running  = queue.filter(t=>t.status==="running").length;
  const completed = queue.filter(t=>t.status==="completed").length;
  if (counts) counts.textContent = `${pending} pending · ${running} running · ${completed} done`;
  updateQueuePill();

  if (!queue.length) {
    el.innerHTML = '<div class="empty-state">No active tasks.</div>';
    return;
  }

  const recent = [...queue].reverse().slice(0, 8);
  el.innerHTML = recent.map(item => {
    const agObj  = S.agents[item.agent];
    const color  = agObj?.color || "#8ba3c0";
    const agTitle = agObj?.title || "";
    const pillCls = item.status === "running" ? "pill-running" : item.status === "completed" ? "pill-done" : "pill-pending";
    const pillTxt = item.status === "running" ? "RUNNING" : item.status === "completed" ? "DONE" : "PENDING";
    const summary = item.summary || item.task || "";
    const displayText = summary.length > 120 ? summary.slice(0, 120) + "…" : summary;
    const agentButtons = item.status === "running" ? `
      <button class="btn-force btn-sm" onclick="forceComplete(${item.id})">Force Complete</button>
      <button class="btn-cancel" onclick="wsSend({type:'cancel_worker',agent:'${item.agent}'})">Cancel</button>
    ` : "";

    return `<div class="task-card ${item.status}">
      <div class="task-card-header">
        <div class="task-agent-av">${getAnimeAvatar(item.agent) || ""}</div>
        <span class="task-id-badge">#${item.id}</span>
        <span class="task-agent-tag" style="color:${color};background:${color}18;border:1px solid ${color}30">${esc(item.agent.toUpperCase())}</span>
        <span style="font-size:10px;color:var(--text-mute);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:80px;font-family:var(--font-body)">${esc(agTitle)}</span>
        <span class="task-status-pill ${pillCls}">${pillTxt}</span>
      </div>
      <div class="task-summary${item.status==="pending"?" muted":""}">${esc(displayText)}</div>
      ${item.status === "running" ? `<div class="task-progress-bar"><div class="task-progress-fill"></div></div>` : ""}
      ${agentButtons ? `<div class="task-actions">${agentButtons}</div>` : ""}
    </div>`;
  }).join("");
}

function forceComplete(taskId) {
  wsSend({ type: "force_complete", task_id: taskId });
  toast(`Force completing task #${taskId}…`, "warn");
}

function resetTask(taskId) {
  wsSend({ type: "reset_task", task_id: taskId });
  toast(`Task #${taskId} reset to pending.`, "info");
}

function updateQueuePill() {
  const active = S.workQueue.filter(t => t.status !== "completed").length;
  const el = $id("queue-val");
  if (el) el.textContent = active;
}

// ── Storage ───────────────────────────────────────────────────────────────────

async function loadStorageStats() {
  try {
    const r = await fetch("/api/storage");
    const d = await r.json();
    const pct = d.percent;

    // Header pill
    const el = $id("storage-val");
    if (el) el.textContent = `${d.used_gb}/${d.max_gb}GB`;
    const pill = $id("storage-pill");
    if (pill) pill.className = `pill ${pct > 85 ? "warn" : "ok"}`;

    // System bar
    const fill = $id("sys-storage-fill");
    if (fill) {
      fill.style.width = pct + "%";
      fill.style.background = pct > 85 ? "var(--err)" : pct > 70 ? "var(--warn)" : "var(--ok)";
    }
    const txt = $id("sys-storage-txt");
    if (txt) txt.textContent = `${d.used_gb}GB`;
  } catch (_) {}
}

// ── Capabilities ──────────────────────────────────────────────────────────────

async function loadCapabilities() {
  try {
    const r = await fetch("/api/capabilities");
    const d = await r.json();
    const el = $id("skills-grid");
    if (!el || !d.skills) return;
    el.innerHTML = d.skills.map(s => `
      <div class="skill-item ${s.active ? "active" : ""}">
        <div class="skill-dot"></div>
        <div class="skill-name">${esc(s.name)}</div>
      </div>`).join("");
  } catch (_) {}
}

// ── Hire contractor ───────────────────────────────────────────────────────────

function openHireModal() {
  $id("hire-modal").style.display = "flex";
}

async function hireContractor() {
  const name  = $id("hire-name").value.trim();
  const title = $id("hire-title").value.trim();
  const stack = $id("hire-stack").value.trim();
  if (!name) return;

  const res = await fetch("/api/hire", {
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({name,title,stack})
  });
  const d = await res.json();
  if (d.ok) {
    toast(`${name} hired as contractor!`, "success");
    $id("hire-modal").style.display = "none";
    // Refresh agents
    const ar = await fetch("/api/agents");
    S.agents = await ar.json();
    S.agentOrder = Object.keys(S.agents);
    renderAgentTabs();
    renderOrgChart();
  }
}

// ── Task History ─────────────────────────────────────────────────────────────

let _registryTab = 'active';

function switchRegistryTab(tab) {
  _registryTab = tab;
  document.getElementById('task-registry').style.display      = tab === 'active'  ? '' : 'none';
  document.getElementById('task-history-panel').style.display = tab === 'history' ? '' : 'none';
  document.getElementById('tab-active').classList.toggle('active',  tab === 'active');
  document.getElementById('tab-history').classList.toggle('active', tab === 'history');
}

function renderTaskHistory(items) {
  const el = document.getElementById('task-history-list');
  if (!el) return;
  if (!items || !items.length) {
    el.innerHTML = '<div class="empty-state">Completed tasks will appear here.</div>';
    return;
  }
  const agentColor_ = id => {
    const m = {ceo:"#00d4ff",backend:"#ff8c42",frontend:"#f472b6",qa:"#a78bfa",devops:"#34d399"};
    return (S.agents[id] && S.agents[id].color) || m[id] || "#8ba3c0";
  };
  el.innerHTML = items.slice(0, 12).map(h => {
    const color = agentColor_(h.agent);
    const summary = h.summary || h.task || "Task completed";
    const ts = h.ts ? h.ts.slice(0, 10) : "";
    const resumeMsg = `Continue from: "${(h.task||"").slice(0, 80)}"`;
    return `<div class="history-card">
      <div class="history-av">${getAnimeAvatar(h.agent) || ""}</div>
      <div class="history-body">
        <div class="history-summary">${esc(summary.slice(0, 200))}</div>
        <div class="history-meta">
          <span class="history-agent-tag" style="color:${color}">${esc(h.agent)}</span>
          ${ts ? `<span>${ts}</span>` : ""}
        </div>
      </div>
      <button class="btn-continue" onclick="resumeTask(${JSON.stringify(resumeMsg)})">↻ Resume</button>
    </div>`;
  }).join("");
}

function resumeTask(msg) {
  switchAgent(CEO_ID);
  switchTab('chat');
  const inp = document.getElementById('message-input');
  if (inp) { inp.value = msg; inp.focus(); }
}

// ── Rebuild & Changelog ───────────────────────────────────────────────────────

function triggerRebuild() {
  if (!confirm('Trigger Docker rebuild? The app will restart (~2 minutes).')) return;
  fetch('/api/rebuild', { method: 'POST' })
    .then(r => r.json())
    .then(d => toast('🔧 ' + (d.message || 'Rebuild initiated')))
    .catch(() => toast('⚠ Could not reach rebuild API'));
}

function renderChangelog(items) {
  const el = document.getElementById('intel-changelog');
  if (!el) return;
  if (!items || !items.length) {
    el.innerHTML = '<div class="intel-empty">No improvements logged yet</div>';
    return;
  }
  const recent = [...items].reverse().slice(0, 5);
  el.innerHTML = recent.map(e => `
    <div class="intel-entry">
      <span class="intel-dot">◆</span>
      <span class="intel-feature">${esc(e.feature || '(unnamed)')}</span>
      <span class="intel-date">${(e.timestamp || '').slice(0, 10)}</span>
    </div>
  `).join('');
}

// ── Email Command Channel ─────────────────────────────────────────────────────

const EMAIL_STATE_META = {
  received:          { label: "Received",          color: "var(--text-mute)",  icon: "📥" },
  verifying:         { label: "Verifying Identity", color: "var(--warn)",      icon: "🔐" },
  planning:          { label: "CEO Planning…",      color: "#60a5fa",          icon: "🧠" },
  awaiting_approval: { label: "Awaiting Approval",  color: "#fb923c",          icon: "⏳" },
  executing:         { label: "Executing",           color: "var(--ceo)",      icon: "⚙" },
  reporting:         { label: "Report Sent",         color: "var(--ok)",       icon: "📤" },
  done:              { label: "Done",                color: "var(--ok)",       icon: "✅" },
  rejected:          { label: "Rejected",            color: "var(--err)",      icon: "🚫" },
};

async function loadEmailTasks() {
  try {
    const r = await fetch("/api/email-tasks");
    const tasks = await r.json();
    renderEmailTasks(tasks);
  } catch (_) {}
}

function renderEmailTasks(tasks) {
  const el    = $id("email-task-list");
  const cnt   = $id("email-task-counts");
  if (!el) return;

  if (!tasks || !tasks.length) {
    el.innerHTML = `<div style="color:var(--text-mute);font-size:12px;text-align:center;padding:20px;">
      No email tasks yet. Send an email to <code style="font-size:11px;">cid.subaru.ai@gmail.com</code> to get started.
    </div>`;
    if (cnt) cnt.textContent = "";
    return;
  }

  const active = tasks.filter(t => !["done","rejected"].includes(t.state)).length;
  if (cnt) cnt.textContent = `${active} active · ${tasks.length} total`;

  el.innerHTML = tasks.slice(0, 10).map(t => {
    const meta = EMAIL_STATE_META[t.state] || { label: t.state, color: "var(--text-mute)", icon: "?" };
    const fromDisplay = esc(t.from_name || t.from_email || "unknown");
    const subj = esc((t.subject || "(no subject)").slice(0, 60));
    const timeAgo = fmtRelativeTime(t.updated);
    const busy = ["planning", "executing"].includes(t.state);

    return `
    <div class="task-item" style="border-left:3px solid ${meta.color};">
      <div class="task-header" style="gap:6px;">
        <span style="font-size:13px;">${meta.icon}</span>
        <span style="font-size:12px;font-weight:600;color:var(--text);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${subj}</span>
        <span style="font-size:10px;font-weight:700;color:${meta.color};white-space:nowrap;${busy ? 'animation:pulse 1.5s infinite;' : ''}">${meta.label}</span>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:4px;">
        <span style="font-size:11px;color:var(--text-sub);">From: ${fromDisplay}</span>
        <span style="font-size:10px;color:var(--text-mute);">${timeAgo}</span>
      </div>
      ${t.plan ? `<div style="font-size:11px;color:var(--text-mute);margin-top:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">📋 ${esc(t.plan.slice(0,80))}…</div>` : ""}
    </div>`;
  }).join("");
}

async function pollEmailNow() {
  toast("Checking inbox…", "info");
  try {
    await fetch("/api/email-tasks/poll", { method: "POST" });
    setTimeout(loadEmailTasks, 3000);
    toast("Inbox checked!", "success");
  } catch (_) {
    toast("Poll failed", "error");
  }
}

// ── Periodic refresh ──────────────────────────────────────────────────────────

function startPeriodicRefresh() {
  setInterval(loadStorageStats, 30000);
  setInterval(loadEmailTasks, 15000);  // check email tasks more often

  // Expose last message time for diagnostics
  let _lastMsg = Date.now();
  window._lastMsgTime = () => _lastMsg;

  // Tick: update active task timers and team dots every 3s
  setInterval(() => {
    updateSysTeamDots();
    // Pulse the queue pill if there are active tasks
    const active = S.workQueue.filter(t => t.status !== "completed").length;
    const qpill = $id("queue-pill");
    if (qpill) {
      qpill.style.borderColor = active > 0 ? "rgba(251,191,36,.35)" : "";
      qpill.style.color       = active > 0 ? "var(--warn)" : "";
    }
  }, 3000);
}

// ── Boot ──────────────────────────────────────────────────────────────────────

function init() {
  initInputEvents();
  initVoice();
  startPeriodicRefresh();
  boot();
}

init();
