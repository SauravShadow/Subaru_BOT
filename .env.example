ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...   # optional — for mounting repos into sessions

# Email notifications (optional — enables [EMAIL_USER:...] in CEO responses)
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx   # Gmail App Password (not your login password)
USER_EMAIL=recipient@gmail.com
SMTP_HOST=smtp.gmail.com        # default
SMTP_PORT=587                   # default

# Telnyx telephony (Call Control)
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_CONNECTION_ID=
TELNYX_PHONE_NUMBER=
TELNYX_VOICE=female
BASE_URL=
